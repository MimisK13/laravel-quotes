{
    "name": "mimisk/laravel-quotes",
    "description": "Simple quote utilities for Laravel applications.",
    "license": "MIT",
    "authors": [
        {
            "name": "Mimis K",
            "email": "mimisk88@gmail.com",
            "homepage": "https://mimisk.com"
        }
    ],
    "homepage": "https://github.com/MimisK13/laravel-quotes",
    "keywords": [
        "laravel",
        "quotes",
        "mimisk"
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mimisk\\LaravelQuotes\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mimisk\\LaravelQuotes\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --colors=always",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mimisk\\LaravelQuotes\\LaravelQuotesServiceProvider"
            ],
            "aliases": {
                "Quotes": "Mimisk\\LaravelQuotes\\Facades\\Quotes"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
